{
  "name": "@betting-engine/bet-service",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"No lint configured yet for bet-service\"",
    "test": "echo \"No tests configured yet for bet-service\"",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "migration:run": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:run",
    "migration:revert": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:revert"
  },
  "dependencies": {
    "@betting-engine/observability": "workspace:*",
    "@betting-engine/shared-kernel": "workspace:*",
    "@nestjs/axios": "^3.1.3",
    "@nestjs/common": "^10.4.20",
    "@nestjs/core": "^10.4.20",
    "@nestjs/microservices": "^10.4.20",
    "@nestjs/platform-express": "^10.4.20",
    "@nestjs/typeorm": "^10.0.2",
    "axios": "^1.7.9",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "kafkajs": "^2.2.4",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.27",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "tsx": "^4.20.6",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^6.0.3"
  }
}