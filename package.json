{
  "name": "bet_engine",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "turbo run test",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "dev": "turbo run dev --parallel",
    "format": "turbo run format",
    "docker:up": "docker compose up -d --wait",
    "docker:down": "docker compose down --remove-orphans",
    "docker:reset": "docker compose down -v --remove-orphans",
    "docker:cleanup:legacy": "node -e \"require('child_process').spawnSync('docker',['rm','-f','betengine-postgres','betengine-redis','betengine-zookeeper','betengine-kafka','betengine-kafka-setup'],{stdio:'inherit'});\"",
    "docker:logs": "docker compose logs -f --tail=200",
    "docker:ps": "docker compose ps",
    "docker:topics": "docker compose exec kafka kafka-topics --bootstrap-server kafka:29092 --list",
    "docker:topics:create": "docker compose run --rm kafka-setup",
    "docker:up:with-topics": "docker compose up -d --wait && docker compose run --rm kafka-setup",
    "docker:test:up": "docker compose -f docker-compose.test.yml up -d",
    "docker:test:down": "docker compose -f docker-compose.test.yml down -v --remove-orphans",
    "docker:prometheus": "docker compose up -d prometheus",
    "docker:grafana": "docker compose up -d grafana",
    "e2e:consumer": "node scripts/e2e-publish-verify.js",
    "ci:check": "pnpm lint && pnpm typecheck && pnpm build && pnpm test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  }
}
